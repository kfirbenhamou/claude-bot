# Copy this file to .env and fill in your real values
# Never commit .env to git!

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
OPENAI_API_KEY=your_openai_api_key

# Optional: OpenAI models (choose what your account has access to)
# Stronger (more accurate) but more expensive: gpt-4o
# Cheaper (still good): gpt-4o-mini
OPENAI_INTENT_MODEL=gpt-4o-mini
OPENAI_AGENT_MODEL=gpt-4o
OPENAI_QA_MODEL=gpt-4o-mini

# Get this by adding the bot to the group, sending a message,
# then visiting: https://api.telegram.org/bot<TOKEN>/getUpdates
FAMILY_GROUP_CHAT_ID=-1001234567890

# Path to your SQLite database file
DB_PATH=family_bot.db

# Timezone (Israel)
TIMEZONE=Asia/Jerusalem

# Optional: Late delivery / repeat behavior
LATE_DELIVERY_HOURS=4
GROUP_REMIND_REPEAT_MINUTES=30

# Optional: TTS (Text-to-Speech) for the 🔊 האזן button on events
# Model: tts-1 (fast/cheap) or tts-1-hd (higher quality)
# Voice: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
