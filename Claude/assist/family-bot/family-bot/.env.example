# Copy this file to .env and fill in your real values
# Never commit .env to git!

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
ANTHROPIC_API_KEY=your_anthropic_api_key

# Anthropic models
ANTHROPIC_INTENT_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_AGENT_MODEL=claude-sonnet-4-6
ANTHROPIC_QA_MODEL=claude-haiku-4-5-20251001

# Get this by adding the bot to the group, sending a message,
# then visiting: https://api.telegram.org/bot<TOKEN>/getUpdates
FAMILY_GROUP_CHAT_ID=-1001234567890

# Path to your SQLite database file
DB_PATH=family_bot.db

# Timezone (Israel)
TIMEZONE=Asia/Jerusalem

# Optional: Late delivery / repeat behavior
LATE_DELIVERY_HOURS=4
GROUP_REMIND_REPEAT_MINUTES=30

# Optional TTS for the 🔊 האזן button (requires OPENAI_API_KEY — omit to disable voice)
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=onyx
# OPENAI_TTS_INSTRUCTIONS=
# OPENAI_TTS_DAILY_SUMMARY_INSTRUCTIONS=
# OPENAI_TTS_MAX_CHARS=3800

# ── Google Calendar sync (optional) ──────────────────────────────────────────
# Setup: run `python scripts/gcal_auth.py` once to generate token.json.
GCAL_CREDENTIALS_PATH=credentials.json
GCAL_TOKEN_PATH=token.json
GCAL_CALENDAR_ID=primary
